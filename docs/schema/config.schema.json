{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/konstruktor1/unifi-stubd/docs/schema/config.schema.json",
  "title": "unifi-stubd configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "operation_mode": {
      "type": "string",
      "enum": ["stub", "bridge-observe", "observe", "port-map", "host-direct", "macvlan"]
    },
    "controller_url": {
      "type": "string"
    },
    "profile": {
      "type": "string"
    },
    "profile_file": {
      "type": "string"
    },
    "profile_dir": {
      "type": "string"
    },
    "mac": {
      "type": "string"
    },
    "ip": {
      "type": "string",
      "format": "ipv4",
      "description": "Controller-facing device identity or transport IP. For gateway profiles this is not automatically a WAN or LAN port address; assign gateway data-plane IPs with port_overrides[].ip."
    },
    "hostname": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "model_display": {
      "type": "string"
    },
    "ports": {
      "type": "integer",
      "minimum": 0
    },
    "link_speed": {
      "type": "integer",
      "minimum": 0
    },
    "uplink_speed": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["auto", "profile"]
        },
        {
          "type": "integer",
          "minimum": 1
        }
      ]
    },
    "uplink_port": {
      "type": "integer",
      "minimum": 0
    },
    "uplink_neighbor": {
      "oneOf": [
        {
          "$ref": "#/$defs/neighbor"
        },
        {
          "type": "null"
        }
      ]
    },
    "port_neighbors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/port_neighbor"
      }
    },
    "port_overrides": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/port_override"
      }
    },
    "wan_health": {
      "$ref": "#/$defs/wan_health"
    },
    "bridge_observe": {
      "$ref": "#/$defs/bridge_observe"
    },
    "port_mappings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/port_mapping"
      }
    },
    "observe_interface": {
      "type": "string"
    },
    "observe_bridge": {
      "type": "string"
    },
    "lldp_source": {
      "type": "string",
      "enum": ["off", "lldpd"]
    },
    "traffic_source": {
      "type": "string",
      "enum": ["off"]
    },
    "traffic_rates_enabled": {
      "type": "boolean",
      "default": false
    },
    "log_source": {
      "type": "string",
      "enum": ["off", "journalctl", "syslog"]
    },
    "proc_source": {
      "type": "string",
      "enum": ["off", "procfs"]
    },
    "dbus_enabled": {
      "type": "boolean"
    },
    "dbus_bus": {
      "type": "string",
      "enum": ["system", "session"]
    },
    "syslog_path": {
      "type": "string"
    },
    "instance_guard": {
      "type": "string",
      "enum": ["fail", "warn", "off"],
      "description": "Host-global duplicate instance guard. fail aborts a second live daemon, warn logs and continues, off disables the guard for intentional multi-instance labs."
    },
    "instance_guard_path": {
      "type": "string",
      "description": "Advisory lock file path used by instance_guard."
    },
    "version": {
      "type": "string"
    },
    "interval_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "no_discovery": {
      "type": "boolean"
    },
    "discovery_interface": {
      "type": "string"
    },
    "discovery_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "management_lan": {
      "$ref": "#/$defs/management_lan",
      "description": "Switch management VLAN model. Gateway profiles keep WAN/LAN data-plane assignments in port_overrides instead of management_lan."
    },
    "ssh_listen": {
      "type": "string",
      "description": "Optional built-in advanced-adoption SSH listen address. Leave empty for the normal inform-based adoption path; enable only in isolated labs that need SSH/set-inform compatibility."
    },
    "ssh_user": {
      "type": "string",
      "description": "Username accepted by the optional advanced-adoption SSH shim when ssh_listen is enabled."
    },
    "ssh_password": {
      "type": "string",
      "description": "Password accepted by the optional advanced-adoption SSH shim when ssh_listen is enabled."
    },
    "ssh_host_key_path": {
      "type": "string"
    },
    "state_path": {
      "type": "string"
    },
    "status_path": {
      "type": "string"
    }
  },
  "$defs": {
    "management_lan": {
      "type": "object",
      "description": "Structured switch management VLAN metadata and optional preexisting-interface source binding. It does not create host VLANs and is not used to model gateway WAN/LAN ports.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "vlan": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4094
        },
        "network_name": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["metadata-only", "preexisting-interface", "planned-host-vlan"]
        },
        "interface": {
          "type": "string"
        },
        "ip": {
          "type": "string",
          "format": "ipv4"
        },
        "controller_reachable": {
          "type": "string",
          "enum": ["off", "warn", "required"]
        },
        "adoption_strategy": {
          "type": "string",
          "enum": ["untagged-first", "tagged-only"]
        }
      }
    },
    "neighbor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mac": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "hostname": {
          "type": "string"
        },
        "ip": {
          "type": "string",
          "format": "ipv4"
        },
        "vlan": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4094
        },
        "static": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "description": "Neighbor type; defaults to usw for uplink_neighbor."
        },
        "age": {
          "type": "integer",
          "minimum": 0
        },
        "uptime": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "port_neighbor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1
        },
        "mac": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "hostname": {
          "type": "string"
        },
        "ip": {
          "type": "string",
          "format": "ipv4"
        },
        "vlan": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4094
        },
        "static": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "description": "Neighbor type; defaults to client for port_neighbors."
        },
        "age": {
          "type": "integer",
          "minimum": 0
        },
        "uptime": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["port"]
    },
    "wan_health": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": ["off", "static", "ping"],
          "default": "off",
          "description": "Read-only gateway WAN health source. off disables active probing, static uses port_overrides wan_* hints, ping runs the local OS ping command and updates WAN telemetry only."
        },
        "interval_seconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Sampling interval for active WAN health probes. It has no effect when source is off or static."
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1,
          "description": "Per-target timeout for active WAN health probes."
        },
        "targets": {
          "type": "array",
          "description": "Ping targets mapped to effective gateway WAN or WAN2 ports. The port selects the telemetry row; the ICMP packet follows normal host routing.",
          "items": {
            "$ref": "#/$defs/wan_health_target"
          }
        }
      }
    },
    "wan_health_target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "description": "One-based represented UniFi port index. The resolved port role must be wan or wan2 when source is ping."
        },
        "host": {
          "type": "string",
          "minLength": 1,
          "description": "IP address or hostname passed to the local ping command."
        }
      },
      "required": ["port", "host"]
    },
    "port_override": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "description": "One-based represented profile port index."
        },
        "name": {
          "type": "string",
          "description": "Optional controller display name for this represented port."
        },
        "interface": {
          "type": "string",
          "description": "Local host interface used as read-only source data for this port. Gateway payloads expose it as source_interface, not as controller ifname."
        },
        "mac": {
          "type": "string",
          "description": "Optional MAC override for the represented port."
        },
        "ip": {
          "type": "string",
          "description": "Optional IPv4 address shown for the represented gateway interface."
        },
        "netmask": {
          "type": "string",
          "description": "Optional IPv4 netmask paired with ip for the represented gateway interface."
        },
        "role": {
          "type": "string",
          "enum": ["", "wan", "lan", "wan2", "lan2", "unassigned"],
          "description": "Effective gateway function for this profile port. It does not rename the profile-derived controller ifname."
        },
        "network_group": {
          "type": "string",
          "description": "Controller network group label mirrored into gateway tables, for example WAN, WAN2, or LAN. This is payload metadata only."
        },
        "portconf_id": {
          "type": "string",
          "description": "Optional controller port profile assignment ID mirrored into gateway port tables. It is not applied to the host."
        },
        "networkconf_id": {
          "type": "string",
          "description": "Optional controller network assignment ID mirrored into gateway WAN/LAN metadata. It is not applied to the controller or host."
        },
        "native_networkconf_id": {
          "type": "string",
          "description": "Optional native network assignment ID mirrored into gateway switch-port metadata. It is display/payload data only."
        },
        "network_name": {
          "type": "string",
          "description": "Optional controller network display name mirrored into gateway tables."
        },
        "vlan": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4094,
          "description": "Controller display metadata mirrored into gateway tables. The daemon does not create VLANs, edit VLAN profiles, or mutate host interfaces."
        },
        "wan_uptime_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Static WAN telemetry hint used when wan_health is off or static, or overwritten by ping results when wan_health.source is ping."
        },
        "wan_latency_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Static WAN latency telemetry hint in milliseconds."
        },
        "wan_downtime_seconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Static WAN downtime telemetry hint in seconds."
        },
        "wan_connected": {
          "type": "boolean",
          "description": "Static WAN connected-state telemetry hint."
        },
        "speed": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional represented link speed in Mbps. It changes payload display only."
        },
        "media": {
          "type": "string",
          "description": "Optional represented media label such as RJ45 or SFP+."
        },
        "up": {
          "type": "boolean",
          "description": "Optional represented link-state override. It does not administratively change the host port."
        }
      },
      "required": ["port"]
    },
    "bridge_observe": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bridge": {
          "type": "string"
        },
        "uplink_interface": {
          "type": "string"
        },
        "ignored_members": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "member_port_map": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/bridge_member_port_map"
          }
        }
      }
    },
    "bridge_member_port_map": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "member": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": ["member", "port"]
    },
    "port_mapping": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1
        },
        "interface": {
          "type": "string"
        },
        "disabled": {
          "type": "boolean"
        },
        "unmapped": {
          "type": "boolean"
        }
      },
      "required": ["port"]
    }
  }
}
