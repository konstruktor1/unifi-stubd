# shellcheck shell=sh
# Default UTM profile values for the UDM Pro SE VM lab.
#
# Source this file before running scripts/install-utm-profile.sh or let that
# script source it automatically. Existing environment variables win, so local
# experiments can override any value without editing this file.

: "${UDM_PRO_SE_UTM_NAME:=UDM-Pro-SE-QEMU}"
: "${UDM_PRO_SE_UTM_IFNAME:=en0}"
: "${UDM_PRO_SE_UTM_NETWORK_BACKEND:=utm}"
: "${UDM_PRO_SE_UTM_NETWORK_HARDWARE:=virtio-net-pci}"

# Network 0: UTM Shared/NAT, mapped by firmware mocks to guest eth9, the first
# 10G SFP+ WAN role. The host-port value is written into UTM's plist as the
# intended HTTPS forward, but local tests must still verify that UTM actually
# binds it for the running VM.
: "${UDM_PRO_SE_UTM_SFP_WAN_MODE:=Shared}"
: "${UDM_PRO_SE_UTM_SFP_WAN_MAC:=02:15:6d:00:ea:35}"
: "${UDM_PRO_SE_UTM_HTTPS_HOST_PORT:=10443}"

# Network 1: UTM Host-only, mapped by firmware mocks to guest eth8, the 2.5G
# RJ45 LAN role attached to br0.
: "${UDM_PRO_SE_UTM_LAN_MODE:=Host}"
: "${UDM_PRO_SE_UTM_LAN_MAC:=02:15:6d:00:ea:34}"

# Serial-only VM profile. UTM display, sound, sharing, and USB input are reset
# by the installer script.
: "${UDM_PRO_SE_UTM_MEMORY:=4096}"
: "${UDM_PRO_SE_UTM_SERIAL_PORT:=15555}"
: "${UDM_PRO_SE_UTM_SERIAL_WAIT:=false}"

# Manual network backend fallback. The normal profile uses UTM-managed Network
# entries instead.
: "${UDM_PRO_SE_UTM_NETWORK_MODE:=Host}"
: "${UDM_PRO_SE_UTM_NETWORK_PCI_ADDR:=0x2}"
