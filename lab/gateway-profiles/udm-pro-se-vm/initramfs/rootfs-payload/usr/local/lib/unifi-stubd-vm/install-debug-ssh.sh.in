#!/bin/sh
# Install an optional lab SSH public key.
#
# The key is provided by UDM_PRO_SE_VM_DEBUG_SSH_PUBKEY at build time. If no key
# is configured this script exits without changing SSH configuration.
set +e

PATH=/usr/sbin:/usr/bin:/sbin:/bin

pubkey_b64="@UNIFI_STUBD_VM_DEBUG_SSH_PUBKEY_B64@"
[ -n "$pubkey_b64" ] || exit 0

pubkey=$(printf '%s' "$pubkey_b64" | base64 -d 2>/dev/null || true)
[ -n "$pubkey" ] || exit 0

mkdir -p /root/.ssh
touch /root/.ssh/authorized_keys
grep -qxF "$pubkey" /root/.ssh/authorized_keys 2>/dev/null ||
    printf '%s\n' "$pubkey" >> /root/.ssh/authorized_keys
chmod 0700 /root/.ssh
chmod 0600 /root/.ssh/authorized_keys

if [ -d /etc/dropbear ]; then
    touch /etc/dropbear/authorized_keys
    grep -qxF "$pubkey" /etc/dropbear/authorized_keys 2>/dev/null ||
        printf '%s\n' "$pubkey" >> /etc/dropbear/authorized_keys
    chmod 0600 /etc/dropbear/authorized_keys
fi

if [ -f /etc/ssh/sshd_config ]; then
    mkdir -p /etc/ssh/sshd_config.d
    if ! grep -q '^Include /etc/ssh/sshd_config.d/\*.conf' /etc/ssh/sshd_config; then
        tmp_config=$(mktemp)
        {
            printf '%s\n' 'Include /etc/ssh/sshd_config.d/*.conf'
            cat /etc/ssh/sshd_config
        } > "$tmp_config" &&
            cat "$tmp_config" > /etc/ssh/sshd_config
        rm -f "$tmp_config"
    fi
    cp /usr/local/share/unifi-stubd-vm/ssh/99-unifi-stubd-debug.conf \
        /etc/ssh/sshd_config.d/99-unifi-stubd-debug.conf 2>/dev/null || true
fi

if command -v sshd >/dev/null 2>&1; then
    sshd -t >/dev/null 2>&1 || exit 0
fi

systemctl restart ssh.service >/dev/null 2>&1 ||
    systemctl restart sshd.service >/dev/null 2>&1 ||
    systemctl restart dropbear.service >/dev/null 2>&1 ||
    true

echo "unifi-stubd-vm-debug-ssh: installed lab SSH public key"
